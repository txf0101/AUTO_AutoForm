# DeepSeek direct API runtime settings.
# Keep the real API key in `.env` or type it into the local page for one request.
CHAT_PROVIDER=deepseek
DeepSeek_V4_API=your_deepseek_v4_api_key_here
CHAT_MODEL=deepseek-v4-flash
CHAT_BASE_URL=https://api.deepseek.com
CHAT_API_MODE=chat_completions

# Optional AutoForm path overrides for machines with non-standard installs.
# Leave these blank unless discovery cannot find the local AutoForm R13 layout.
AUTOFORM_INSTALL_DIR=
AUTOFORM_PROGRAM_DATA_DIR=
AUTOFORM_VERSION_DIR=
AUTOFORM_MATERIALS_DIR=
AUTOFORM_SCRIPTS_DIR=
AUTOFORM_TEST_DIR=
AUTOFORM_QUICKLINK_TEMPLATES_DIR=
AUTOFORM_SYSTEM_CONFIG_FILE=
AUTOFORM_HELP_LINKS_FILE=
