{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.cad_measurement_result.v1",
  "title": "CadMeasurementResult",
  "type": "object",
  "required": [
    "schema_version",
    "status",
    "source_geometry_path",
    "parser",
    "unit",
    "axis_aligned_bbox",
    "oriented_bbox",
    "length",
    "width",
    "thickness",
    "measurement_method",
    "confidence",
    "evidence_dir",
    "logs",
    "failure_reason",
    "blocked_reason",
    "filename_dimension_candidate"
  ],
  "properties": {
    "schema_version": { "const": "autoform.cad_measurement_result.v1" },
    "status": { "enum": ["completed", "blocked", "failed", "running"] },
    "source_geometry_path": { "type": "string" },
    "source_sha256": { "type": "string" },
    "parser": { "type": "string" },
    "unit": { "type": "string" },
    "axis_aligned_bbox": { "type": ["object", "null"] },
    "oriented_bbox": { "type": ["object", "null"] },
    "length": { "type": ["number", "integer", "null"] },
    "width": { "type": ["number", "integer", "null"] },
    "thickness": { "type": ["number", "integer", "null"] },
    "measurement_method": { "type": "string" },
    "confidence": { "type": "string" },
    "evidence_dir": { "type": "string" },
    "logs": { "type": "array", "items": { "type": "string" } },
    "failure_reason": { "type": "string" },
    "blocked_reason": { "type": "string" },
    "filename_dimension_candidate": { "type": ["object", "null"] },
    "parser_probe": { "type": "object" }
  },
  "additionalProperties": true
}
