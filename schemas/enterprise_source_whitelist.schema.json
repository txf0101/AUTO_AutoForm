{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.enterprise_source_whitelist.v1",
  "title": "EnterpriseSourceWhitelistRow",
  "type": "object",
  "required": [
    "source_id",
    "title",
    "path_or_url",
    "source_type",
    "source_group",
    "access_mode",
    "capture_policy",
    "allowed_actions",
    "prohibited_actions",
    "license_status",
    "permission_level",
    "review_status",
    "owner",
    "version",
    "applicability",
    "limitation",
    "evidence_refs"
  ],
  "properties": {
    "source_id": {
      "type": "string",
      "pattern": "^source_[a-z0-9_]+$"
    },
    "title": {
      "type": "string"
    },
    "path_or_url": {
      "type": "string"
    },
    "source_type": {
      "type": "string"
    },
    "source_group": {
      "type": "string"
    },
    "access_mode": {
      "enum": [
        "local_read_only",
        "metadata_only_until_r14",
        "manual_review_required"
      ]
    },
    "capture_policy": {
      "enum": [
        "metadata_only",
        "manual_sample_after_review",
        "blocked"
      ]
    },
    "allowed_actions": {
      "type": "string"
    },
    "prohibited_actions": {
      "type": "string"
    },
    "license_status": {
      "type": "string"
    },
    "permission_level": {
      "type": "string"
    },
    "review_status": {
      "enum": [
        "candidate",
        "reviewed",
        "blocked"
      ]
    },
    "owner": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "applicability": {
      "type": "string"
    },
    "limitation": {
      "type": "string"
    },
    "evidence_refs": {
      "type": "string"
    }
  },
  "additionalProperties": false
}
