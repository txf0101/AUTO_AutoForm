{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.script_approval_record.v1",
  "title": "ScriptApprovalRecord",
  "type": "object",
  "required": [
    "schema_version",
    "object_type",
    "approval_id",
    "status",
    "sandbox_id",
    "skill_id",
    "risk_level",
    "approved_by",
    "validation_report_hash",
    "created_at"
  ],
  "properties": {
    "schema_version": { "const": "autoform.script_approval_record.v1" },
    "object_type": { "const": "ScriptApprovalRecord" },
    "approval_id": { "type": "string" },
    "status": { "enum": ["approved", "revoked"] },
    "sandbox_id": { "type": "string" },
    "sandbox_dir": { "type": "string" },
    "skill_id": { "type": "string" },
    "risk_level": { "enum": ["L2", "L3", "L4"] },
    "approved_by": { "type": "string" },
    "approved_actions": { "type": "array", "items": { "type": "string" } },
    "validation_report_hash": { "type": "string" },
    "validation_report_path": { "type": "string" },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
