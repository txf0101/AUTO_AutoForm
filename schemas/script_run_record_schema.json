{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.script_run_record.v1",
  "title": "ScriptRunRecord",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "skill_id",
    "skill_version",
    "caller_agent",
    "executor",
    "params_hash",
    "status",
    "started_at",
    "finished_at",
    "sandbox_dir",
    "evidence_dir",
    "logs",
    "artifacts",
    "validation_report",
    "failure_summary"
  ],
  "properties": {
    "schema_version": { "const": "autoform.script_run_record.v1" },
    "run_id": { "type": "string" },
    "skill_id": { "type": "string" },
    "skill_version": { "type": "string" },
    "caller_agent": { "type": "string" },
    "executor": { "type": "string" },
    "params_hash": { "type": "string" },
    "status": { "enum": ["completed", "blocked", "failed", "planned", "rejected"] },
    "started_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "sandbox_dir": { "type": "string" },
    "run_dir": { "type": "string" },
    "evidence_dir": { "type": "string" },
    "logs": { "type": "array", "items": { "type": "string" } },
    "artifacts": { "type": "array", "items": { "type": "string" } },
    "validation_report": { "type": "object" },
    "failure_summary": { "type": ["object", "null"] },
    "result": { "type": "object" }
  },
  "additionalProperties": true
}
