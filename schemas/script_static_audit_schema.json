{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.script_static_audit.v1",
  "title": "ScriptStaticAudit",
  "type": "object",
  "required": ["schema_version", "object_type", "status", "created_at"],
  "properties": {
    "schema_version": { "const": "autoform.script_static_audit.v1" },
    "object_type": { "const": "ScriptStaticAudit" },
    "status": { "enum": ["passed", "failed", "warning"] },
    "script_path": { "type": "string" },
    "root": { "type": "string" },
    "file_count": { "type": "integer" },
    "checks": { "type": "array", "items": { "type": "object" } },
    "files": { "type": "array", "items": { "type": "object" } },
    "created_at": { "type": "string" }
  },
  "additionalProperties": true
}
