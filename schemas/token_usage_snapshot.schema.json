{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "autoform-agent.schemas.token_usage_snapshot.v1",
  "title": "TokenUsageSnapshot",
  "type": "object",
  "required": [
    "snapshot_id",
    "run_id",
    "agent_id",
    "provider",
    "model",
    "input_tokens",
    "output_tokens",
    "cached_tokens",
    "total_tokens",
    "captured_at"
  ],
  "properties": {
    "object_type": {
      "const": "TokenUsageSnapshot"
    },
    "snapshot_id": {
      "type": "string",
      "pattern": "^usage_[a-z0-9_]+$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[a-z0-9_]+$"
    },
    "agent_id": {
      "type": "string"
    },
    "provider": {
      "type": "string"
    },
    "model": {
      "type": "string"
    },
    "input_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "output_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "cached_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "total_tokens": {
      "type": "integer",
      "minimum": 0
    },
    "captured_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": true
}
